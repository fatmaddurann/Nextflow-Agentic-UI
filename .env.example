# =====================================================
# Nextflow-Agentic-UI Environment Configuration
# =====================================================
# Copy this file to .env and fill in your values

# --- OpenAI / LLM Settings ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
# For local LLMs (Ollama), set: OPENAI_BASE_URL=http://localhost:11434/v1

# --- Database Settings ---
DATABASE_URL=sqlite:///./data/workflows.db
# For PostgreSQL: postgresql://user:password@localhost:5432/nextflow_agentic

# --- FastAPI Settings ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_long_random_secret_key
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Nextflow Settings ---
NEXTFLOW_WORK_DIR=./pipeline/work
NEXTFLOW_OUTPUT_DIR=./pipeline/results
NEXTFLOW_LOG_DIR=./pipeline/logs
NEXTFLOW_BINARY=nextflow

# --- Docker Settings ---
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=nextflow-agentic-net

# --- RAG / Vector Store Settings ---
CHROMA_PERSIST_DIR=./knowledge_base/chroma_db
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# --- Monitoring Settings ---
LOG_POLL_INTERVAL_SECONDS=5
MAX_LOG_LINES=1000

# --- Frontend Settings ---
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
