// =====================================================
// Nextflow-Agentic-UI — Pipeline Configuration
// RNA-Seq Pipeline: FastQC → Trimmomatic → STAR → featureCounts
// =====================================================

manifest {
    name            = 'nf-rnaseq-agentic'
    author          = 'Nextflow-Agentic-UI'
    description     = 'RNA-Seq pipeline with AI-powered monitoring and troubleshooting'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}


params {
    // Input/Output
    reads           = "${projectDir}/test_data/*_{1,2}.fastq.gz"
    outdir          = "${projectDir}/results"
    genome          = null          // Path to reference genome FASTA
    gtf             = null          // Path to GTF annotation file
    star_index      = null          // Path to pre-built STAR index (optional)

    // Tool options
    trimmomatic_adapter = "${projectDir}/data/adapters/TruSeq3-PE.fa"
    min_trim_length     = 36
    star_threads        = 8
    featurecounts_type  = "exon"
    featurecounts_id    = "gene_id"

    // Execution control
    max_memory      = '128.GB'
    max_cpus        = 16
    max_time        = '240.h'
    skip_fastqc     = false
    skip_trimming   = false
    skip_alignment  = false

    // Reporting
    email           = null
    multiqc_config  = null
    tracedir        = "${params.outdir}/pipeline_info"
}


profiles {

    // Local execution (development / testing)
    standard {
        process.executor = 'local'
        docker.enabled   = true
    }

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }

    // Simulated cluster (for testing with local executor but cluster-like resource requests)
    test {
        process.executor    = 'local'
        docker.enabled      = true
        params.max_memory   = '8.GB'
        params.max_cpus     = 4
        params.max_time     = '2.h'
        params.reads        = "${projectDir}/test_data/*_{1,2}.fastq.gz"
        params.genome       = "${projectDir}/test_data/genome/genome.fa"
        params.gtf          = "${projectDir}/test_data/genome/genes.gtf"
        params.star_index   = "${projectDir}/test_data/star_index"
    }

    // CI: stub-run validation without Docker or real data
    ci {
        process.executor    = 'local'
        docker.enabled      = false
        params.reads        = "${projectDir}/test_data/*_{1,2}.fastq.gz"
        params.star_index   = "${projectDir}/test_data/star_index"
        params.gtf          = "${projectDir}/test_data/genome/genes.gtf"
        params.max_memory   = '2.GB'
        params.max_cpus     = 2
        params.max_time     = '1.h'
    }

    // Simulate failures for AI troubleshooting demo
    simulate_failure {
        process.executor    = 'local'
        docker.enabled      = true
        params.star_index   = "/nonexistent/star_index"  // Intentional failure
        params.genome       = null
    }
}


process {
    // Global defaults
    cpus   = { check_max( 1    * task.attempt, 'cpus'   ) }
    memory = { check_max( 6.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h  * task.attempt, 'time'   ) }

    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // Process-specific overrides
    withLabel: process_single {
        cpus   = { check_max( 1                  , 'cpus'   ) }
        memory = { check_max( 6.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }

    withLabel: process_low {
        cpus   = { check_max( 2     * task.attempt, 'cpus'   ) }
        memory = { check_max( 12.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }

    withLabel: process_medium {
        cpus   = { check_max( 6     * task.attempt, 'cpus'   ) }
        memory = { check_max( 36.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h   * task.attempt, 'time'   ) }
    }

    withLabel: process_high {
        cpus   = { check_max( 12    * task.attempt, 'cpus'   ) }
        memory = { check_max( 72.GB * task.attempt, 'memory' ) }
        time   = { check_max( 16.h  * task.attempt, 'time'   ) }
    }

    // Container assignments per process
    withName: FASTQC {
        container  = 'biocontainers/fastqc:v0.11.9_cv8'
        cpus       = 2
        memory     = '4.GB'
    }

    withName: TRIMMOMATIC {
        container  = 'quay.io/biocontainers/trimmomatic:0.39--hdfd78af_2'
        cpus       = 4
        memory     = '8.GB'
    }

    withName: STAR_GENOMEGENERATE {
        container  = 'quay.io/biocontainers/star:2.7.11a--h0033a41_0'
        cpus       = 8
        memory     = '64.GB'
        time       = '2.h'
    }

    withName: STAR_ALIGN {
        container  = 'quay.io/biocontainers/star:2.7.11a--h0033a41_0'
        cpus       = 8
        memory     = '40.GB'
    }

    withName: SAMTOOLS_SORT {
        container  = 'quay.io/biocontainers/samtools:1.18--h50ea8bc_1'
        cpus       = 4
        memory     = '16.GB'
    }

    withName: SAMTOOLS_INDEX {
        container  = 'quay.io/biocontainers/samtools:1.18--h50ea8bc_1'
        cpus       = 2
        memory     = '4.GB'
    }

    withName: FEATURECOUNTS {
        container  = 'quay.io/biocontainers/subread:2.0.6--he4a0461_0'
        cpus       = 4
        memory     = '16.GB'
    }

    withName: MULTIQC {
        container  = 'quay.io/biocontainers/multiqc:1.19--pyhdfd78af_0'
        cpus       = 2
        memory     = '8.GB'
    }
}


docker {
    enabled    = true
    temp       = 'auto'
    runOptions = '--rm'
}


timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline.html"
}

report {
    enabled = true
    file    = "${params.tracedir}/execution_report.html"
}

trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace.txt"
    fields  = 'task_id,hash,native_id,process,tag,status,exit,submit,start,complete,duration,realtime,cpus,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled = true
    file    = "${params.tracedir}/pipeline_dag.svg"
}


def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min( obj, params.max_cpus as int ) }
        catch (all) { return obj }
    }
}
